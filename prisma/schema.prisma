generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum OrganizationPlan {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  FREE
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
  CUSTOMER
}

enum SlipStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
  UNAVAILABLE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  PARTIAL
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  ACH
  CASH
  CHECK
  STRIPE
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  EMERGENCY
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum WorkOrderStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  INVOICED
}

enum FuelType {
  GASOLINE
  DIESEL
  PREMIUM_GASOLINE
  PREMIUM_DIESEL
}

enum StorageStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  EXPORT
  VIEW
}

enum NotificationType {
  RESERVATION_CONFIRMED
  RESERVATION_REMINDER
  PAYMENT_RECEIVED
  INVOICE_OVERDUE
  MAINTENANCE_SCHEDULED
  GENERAL
  SYSTEM
}

// ============ ORGANIZATION & AUTH ============

model Organization {
  id                       String           @id @default(cuid())
  name                     String
  slug                     String           @unique
  email                    String?
  phone                    String?
  address                  String?
  city                     String?
  state                    String?
  zipCode                  String?
  country                  String           @default("US")
  logo                     String?
  plan                     OrganizationPlan @default(TRIAL)
  clerkOrgId               String?          @unique
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  subscriptionPriceInCents Int              @default(150000)
  trialEndsAt              DateTime?
  subscribedAt             DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  // Relations
  users               User[]
  slips               Slip[]
  docks               Dock[]
  reservations        Reservation[]
  customers           Customer[]
  employees           Employee[]
  invoices            Invoice[]
  payments            Payment[]
  fuelInventory       FuelInventory[]
  fuelSales           FuelSale[]
  storageRacks        StorageRack[]
  storageReservations StorageReservation[]
  maintenanceRequests MaintenanceRequest[]
  workOrders          WorkOrder[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  messages            Message[]
  settings            Settings?
  waitingList         WaitingList[]

  @@index([clerkOrgId])
  @@index([slug])
}

model User {
  id             String    @id @default(cuid())
  organizationId String
  clerkUserId    String?   @unique
  email          String
  firstName      String?
  lastName       String?
  avatar         String?
  role           UserRole  @default(EMPLOYEE)
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]
  workOrders   WorkOrder[]
  auditLogs    AuditLog[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([clerkUserId])
}

// ============ SLIPS & DOCKS ============

model Dock {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String   @default("#0284c7")
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slips        Slip[]

  @@index([organizationId])
}

model Slip {
  id             String     @id @default(cuid())
  organizationId String
  dockId         String
  name           String
  number         String
  length         Float
  width          Float?
  maxDraft       Float?
  hasPower       Boolean    @default(true)
  hasWater       Boolean    @default(true)
  hasWiFi        Boolean    @default(true)
  hasCable       Boolean    @default(false)
  isCovered      Boolean    @default(false)
  status         SlipStatus @default(AVAILABLE)
  dailyRate      Decimal?   @db.Decimal(10, 2)
  monthlyRate    Decimal?   @db.Decimal(10, 2)
  annualRate     Decimal?   @db.Decimal(10, 2)
  notes          String?
  positionX      Float?
  positionY      Float?
  widthPixels    Float?
  heightPixels   Float?
  rotation       Float?     @default(0)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dock                Dock                 @relation(fields: [dockId], references: [id], onDelete: Cascade)
  reservations        Reservation[]
  maintenanceRequests MaintenanceRequest[]

  @@unique([organizationId, dockId, number])
  @@index([organizationId])
  @@index([dockId])
  @@index([status])
}

model Reservation {
  id                 String            @id @default(cuid())
  organizationId     String
  slipId             String
  customerId         String
  status             ReservationStatus @default(PENDING)
  startDate          DateTime
  endDate            DateTime
  checkInAt          DateTime?
  checkOutAt         DateTime?
  boatName           String?
  boatLength         Float?
  boatModel          String?
  notes              String?
  source             String?
  referralCode       String?
  totalAmount        Decimal?          @db.Decimal(10, 2)
  depositAmount      Decimal?          @db.Decimal(10, 2)
  isRecurring        Boolean           @default(false)
  autoRenew          Boolean           @default(false)
  cancellationReason String?
  cancelledAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slip         Slip         @relation(fields: [slipId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([organizationId])
  @@index([slipId])
  @@index([customerId])
  @@index([startDate, endDate])
  @@index([status])
}

model WaitingList {
  id              String    @id @default(cuid())
  organizationId  String
  customerId      String
  slipType        String?
  minLength       Float?
  maxLength       Float?
  preferredDockId String?
  notes           String?
  priority        Int       @default(0)
  isActive        Boolean   @default(true)
  requestedAt     DateTime  @default(now())
  fulfilledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
}

// ============ CUSTOMERS ============

model Customer {
  id                     String    @id @default(cuid())
  organizationId         String
  email                  String
  firstName              String
  lastName               String
  phone                  String?
  address                String?
  city                   String?
  state                  String?
  zipCode                String?
  country                String    @default("US")
  companyName            String?
  notes                  String?
  stripeCustomerId       String?
  clerkId                String?   @unique
  preferredPaymentMethod String?
  creditOnFile           Boolean   @default(false)
  referredBy             String?
  tags                   String[]
  isActive               Boolean   @default(true)
  lastVisitAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  boats               Boat[]
  reservations        Reservation[]
  invoices            Invoice[]
  waitingList         WaitingList[]
  storageReservations StorageReservation[]
  messages            Message[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
}

model Boat {
  id                 String   @id @default(cuid())
  customerId         String
  organizationId     String
  name               String
  make               String?
  model              String?
  year               Int?
  length             Float
  beam               Float?
  draft              Float?
  color              String?
  hullType           String?
  registrationNumber String?
  sailNumber         String?
  notes              String?
  imageUrl           String?
  isPrimary          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  customer  Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  insurance Insurance[]
  documents Document[]

  @@index([customerId])
  @@index([organizationId])
}

model Insurance {
  id             String    @id @default(cuid())
  boatId         String
  organizationId String
  provider       String
  policyNumber   String
  coverageAmount Decimal?  @db.Decimal(12, 2)
  expirationDate DateTime?
  isVerified     Boolean   @default(false)
  documentUrl    String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  boat Boat @relation(fields: [boatId], references: [id], onDelete: Cascade)

  @@index([boatId])
  @@index([organizationId])
}

model Document {
  id             String    @id @default(cuid())
  boatId         String
  organizationId String
  type           String
  name           String
  fileUrl        String
  expiryDate     DateTime?
  isVerified     Boolean   @default(false)
  notes          String?
  uploadedBy     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  boat Boat @relation(fields: [boatId], references: [id], onDelete: Cascade)

  @@index([boatId])
  @@index([organizationId])
}

// ============ BILLING ============

model Invoice {
  id              String        @id @default(cuid())
  organizationId  String
  customerId      String?
  reservationId   String?
  invoiceNumber   String
  status          InvoiceStatus @default(DRAFT)
  subtotal        Decimal       @db.Decimal(10, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  amountPaid      Decimal       @default(0) @db.Decimal(10, 2)
  amountDue       Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  dueDate         DateTime
  paidAt          DateTime?
  notes           String?
  lineItems       Json?
  stripeInvoiceId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  reservation  Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  payments     Payment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id                    String        @id @default(cuid())
  organizationId        String
  invoiceId             String
  amount                Decimal       @db.Decimal(10, 2)
  method                PaymentMethod @default(CREDIT_CARD)
  stripePaymentIntentId String?
  stripeChargeId        String?
  status                String        @default("succeeded")
  receiptUrl            String?
  notes                 String?
  processedBy           String?
  paidAt                DateTime      @default(now())
  createdAt             DateTime      @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invoiceId])
  @@index([stripePaymentIntentId])
}

// ============ EMPLOYEES ============

model Employee {
  id               String    @id @default(cuid())
  organizationId   String
  userId           String
  position         String?
  department       String?
  phone            String?
  emergencyContact String?
  emergencyPhone   String?
  isActive         Boolean   @default(true)
  startedAt        DateTime?
  endedAt          DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model WorkOrder {
  id             String              @id @default(cuid())
  organizationId String
  assignedToId   String?
  title          String
  description    String?
  priority       MaintenancePriority @default(MEDIUM)
  status         WorkOrderStatus     @default(DRAFT)
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  actualHours    Float?
  laborCost      Decimal?            @db.Decimal(10, 2)
  partsCost      Decimal?            @db.Decimal(10, 2)
  totalCost      Decimal?            @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([assignedToId])
  @@index([status])
}

model MaintenanceRequest {
  id             String              @id @default(cuid())
  organizationId String
  slipId         String?
  customerId     String?
  title          String
  description    String?
  priority       MaintenancePriority @default(MEDIUM)
  status         MaintenanceStatus   @default(PENDING)
  requestedBy    String?
  assignedToId   String?
  scheduledAt    DateTime?
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slip         Slip?        @relation(fields: [slipId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([slipId])
  @@index([status])
}

// ============ FUEL DOCK ============

model FuelInventory {
  id             String    @id @default(cuid())
  organizationId String
  fuelType       FuelType
  tankId         String?
  tankName       String?
  currentLevel   Float     @default(0)
  capacity       Float
  unit           String    @default("gallons")
  pricePerUnit   Decimal   @db.Decimal(10, 2)
  costPerUnit    Decimal?  @db.Decimal(10, 2)
  reorderPoint   Float?
  lastDeliveryAt DateTime?
  nextDeliveryAt DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, fuelType])
  @@index([organizationId])
}

model FuelSale {
  id                    String   @id @default(cuid())
  organizationId        String
  fuelType              FuelType
  quantity              Float
  unitPrice             Decimal  @db.Decimal(10, 2)
  totalAmount           Decimal  @db.Decimal(10, 2)
  customerName          String?
  boatName              String?
  slipNumber            String?
  paymentMethod         String?
  stripePaymentIntentId String?
  notes                 String?
  soldAt                DateTime @default(now())
  createdAt             DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([fuelType])
  @@index([soldAt])
}

// ============ DRY STORAGE ============

model StorageRack {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  location       String?
  capacity       Int
  occupiedCount  Int           @default(0)
  width          Float?
  height         Float?
  depth          Float?
  weightCapacity Float?
  status         StorageStatus @default(AVAILABLE)
  notes          String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reservations StorageReservation[]

  @@index([organizationId])
}

model StorageReservation {
  id             String            @id @default(cuid())
  organizationId String
  rackId         String
  customerId     String
  status         ReservationStatus @default(PENDING)
  startDate      DateTime
  endDate        DateTime
  boatName       String?
  boatLength     Float?
  boatWeight     Float?
  hasMast        Boolean           @default(false)
  mastHeight     Float?
  notes          String?
  totalAmount    Decimal?          @db.Decimal(10, 2)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rack         StorageRack  @relation(fields: [rackId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([rackId])
  @@index([customerId])
}

// ============ AUDIT & NOTIFICATIONS ============

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  userId         String?
  action         AuditAction
  entity         String
  entityId       String?
  description    String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String?
  type           NotificationType @default(GENERAL)
  title          String
  message        String?
  link           String?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ============ MESSAGING ============
model Message {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String
  sender         MessageSender @default(CUSTOMER)
  subject        String?
  body           String
  isRead         Boolean       @default(false)
  readAt         DateTime?
  createdAt      DateTime      @default(now())
  // Relations
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
  @@index([isRead])
  @@index([createdAt])
}

enum MessageSender {
  CUSTOMER
  STAFF
}

// ============ SETTINGS ============

model Settings {
  id                 String   @id @default(cuid())
  organizationId     String   @unique
  businessHours      Json?
  paymentTerms       String   @default("net30")
  lateFeePercent     Decimal  @default(5.00) @db.Decimal(5, 2)
  lateFeeFlat        Decimal  @default(25.00) @db.Decimal(10, 2)
  defaultDailyRate   Decimal  @default(3.50) @db.Decimal(10, 2)
  defaultMonthlyRate Decimal  @default(85.00) @db.Decimal(10, 2)
  currency           String   @default("USD")
  taxRate            Decimal  @default(0) @db.Decimal(5, 2)
  timezone           String   @default("America/New_York")
  dateFormat         String   @default("MM/DD/YYYY")
  weekStartsOn       Int      @default(0)
  emailNotifications Boolean  @default(true)
  smsNotifications   Boolean  @default(false)
  maintenanceAlerts  Boolean  @default(true)
  lowFuelAlerts      Boolean  @default(true)
  theme              String   @default("dark")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
